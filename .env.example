# Copy to `.env` at the repo root and adjust. Never commit `.env`.

DJANGO_SETTINGS_MODULE=config.settings.local

# Optional overrides (defaults match local Postgres/Redis in base settings)
# POSTGRES_DB=slotflow
# POSTGRES_USER=slotflow
# POSTGRES_PASSWORD=slotflow
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0

# Quick start without Postgres (use from backend/ with SQLite — see README)
# SLOTFLOW_USE_SQLITE=1

# Local dev only: idempotent Django superuser after migrations (`make ensure-superuser`)
# Refused when DEBUG is False. Never enable weak passwords outside a disposable local DB.
# SLOTFLOW_ENSURE_SUPERUSER=1
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me-local-only

# Optional: seed the admin's TOTP device with a fixed hex key so resetting
# the local DB (`make reset-local-db`) and re-bootstrapping (`make bootstrap-local`)
# keeps the authenticator entry on your phone valid — no need to re-scan a QR.
# 40 hex characters (20 bytes) — generate one with:
#   python -c "import secrets; print(secrets.token_hex(20))"
# Or extract your current device's key from the Django shell:
#   from django_otp.plugins.otp_totp.models import TOTPDevice
#   print(TOTPDevice.objects.first().key)
# When set, ensure_superuser creates/updates a confirmed TOTP device named "default".
# SLOTFLOW_ADMIN_TOTP_KEY=0123456789abcdef0123456789abcdef01234567

# Dev-only: bypass 2FA verification so Playwright e2e can exercise
# authenticated flows without computing TOTP codes. Honored ONLY when
# DEBUG is True — staging and production are inert even if set.
# Leave unset in normal local dev; turn on just for e2e runs.
# SLOTFLOW_BYPASS_2FA=1

# Frontend (when a Vite app is added)
# VITE_API_BASE_URL=http://127.0.0.1:8000
